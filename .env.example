# Application
APP_NAME=Running Stats Dashboard API
DEBUG=false

# Database (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/running_stats

# Redis (for cache and Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: S3-compatible storage for raw GPX files
# USE_S3=false
# S3_ENDPOINT_URL=
# S3_BUCKET=running-stats-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
